# 複製此檔案為 .env 並填入實際值
# cp .env.example .env

# JWT 密鑰 (必填)
# 產生方式: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your_secret_key_here

# EC2 公網部署（請替換成你的 EC2 網域或公網 IP）
# 例如：FRONTEND_VITE_API_URL=http://ec2-xx-xx-xx-xx.ap-southeast-2.compute.amazonaws.com:8001
FRONTEND_VITE_API_URL=http://3.27.165.128:8001

# 後端 CORS 白名單（逗號分隔）
# 例如：ALLOWED_ORIGINS=http://3.27.165.128,http://ec2-xx-xx-xx-xx.ap-southeast-2.compute.amazonaws.com
ALLOWED_ORIGINS=http://localhost,http://3.27.165.128
